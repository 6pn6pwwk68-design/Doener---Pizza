<!DOCTYPE html>

<html lang="de">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Pizzeria Panorama Grill</title>

    <style>

        :root {

            --bg-color: #121212;

            --surface-color: #1e1e1e;

            --primary-color: #ff5722;

            --text-color: #ffffff;

            --text-muted: #b3b3b3;

            --border-color: #333333;

        }



        * {

            box-sizing: border-box;

            margin: 0;

            padding: 0;

            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;

        }



        body {

            background-color: var(--bg-color);

            color: var(--text-color);

            line-height: 1.6;

        }



        /* Auth Overlay */

        #auth-overlay {

            position: fixed;

            top: 0;

            left: 0;

            width: 100%;

            height: 100%;

            background-color: rgba(0, 0, 0, 0.9);

            display: flex;

            justify-content: center;

            align-items: center;

            z-index: 1000;

        }



        .auth-card {

            background-color: var(--surface-color);

            padding: 40px;

            border-radius: 8px;

            width: 100%;

            max-width: 400px;

            border: 1px solid var(--border-color);

            text-align: center;

        }



        .auth-card h2 {

            margin-bottom: 24px;

            color: var(--primary-color);

        }



        .form-group {

            margin-bottom: 20px;

            text-align: left;

        }



        .form-group label {

            display: block;

            margin-bottom: 8px;

            color: var(--text-muted);

            font-size: 14px;

        }



        .form-group input {

            width: 100%;

            padding: 12px;

            background-color: var(--bg-color);

            border: 1px solid var(--border-color);

            border-radius: 4px;

            color: var(--text-color);

            font-size: 16px;

        }



        .form-group input:focus {

            border-color: var(--primary-color);

            outline: none;

        }



        .btn-primary {

            width: 100%;

            padding: 14px;

            background-color: var(--primary-color);

            color: white;

            border: none;

            border-radius: 4px;

            font-size: 16px;

            font-weight: bold;

            cursor: pointer;

            transition: background 0.2s;

        }



        .btn-primary:hover {

            background-color: #e64a19;

        }



        /* Main App Layout */

        #main-app {

            display: none;

        }



        header {

            background-color: var(--surface-color);

            border-bottom: 1px solid var(--border-color);

            position: sticky;

            top: 0;

            z-index: 900;

        }



        .main-nav {

            display: flex;

            justify-content: space-between;

            align-items: center;

            max-width: 1200px;

            margin: 0 auto;

            padding: 15px 20px;

        }



        .logo {

            font-size: 22px;

            font-weight: bold;

            color: var(--primary-color);

        }



        .nav-links {

            display: flex;

            list-style: none;

            gap: 20px;

        }



        .nav-links a {

            color: var(--text-color);

            text-decoration: none;

            font-weight: 500;

            padding: 8px 16px;

            border-radius: 4px;

            transition: background 0.2s;

        }



        .nav-links a:hover, .nav-links a.active {

            background-color: var(--primary-color);

        }



        .category-nav {

            background-color: #1a1a1a;

            border-bottom: 1px solid var(--border-color);

            overflow-x: auto;

            white-space: nowrap;

        }



        .
category-container {

            max-width: 1200px;

            margin: 0 auto;

            padding: 10px 20px;

            display: flex;

            gap: 15px;

        }



        .category-link {

            color: var(--text-muted);

            text-decoration: none;

            font-size: 14px;

            padding: 6px 12px;

            border-radius: 20px;

            border: 1px solid var(--border-color);

            transition: all 0.2s;

        }



        .category-link:hover {

            color: var(--text-color);

            border-color: var(--primary-color);

        }



        /* Container & Views */

        .container {

            max-width: 1200px;

            margin: 40px auto;

            padding: 0 20px;

        }



        .view {

            display: none;

        }



        .view.active {

            display: block;

        }



        /* Menu View Styles */

        .category-section {

            margin-bottom: 60px;

            scroll-margin-top: 130px;

        }



        .category-section h2 {

            color: var(--primary-color);

            border-bottom: 2px solid var(--border-color);

            padding-bottom: 10px;

            margin-bottom: 25px;

        }



        .category-note {

            font-style: italic;

            color: var(--text-muted);

            margin-top: -15px;

            margin-bottom: 20px;

            font-size: 14px;

        }



        .menu-grid {

            display: grid;

            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));

            gap: 25px;

        }



        .menu-item {

            background-color: var(--surface-color);

            border: 1px solid var(--border-color);

            border-radius: 8px;

            padding: 20px;

            display: flex;

            flex-direction: column;

            justify-content: space-between;

            position: relative;

        }



        .menu-item.not-available {

            opacity: 0.5;

        }



        .item-info h3 {

            font-size: 18px;

            margin-bottom: 8px;

        }



        .item-description {

            color: var(--text-muted);

            font-size: 14px;

            margin-bottom: 15px;

        }



        .item-footer {

            display: flex;

            justify-content: space-between;

            align-items: center;

            margin-top: auto;

        }



        .item-price {

            font-weight: bold;

            font-size: 16px;

            color: var(--primary-color);

        }



        .btn-add {

            background-color: var(--primary-color);

            color: white;

            border: none;

            width: 32px;

            height: 32px;

            border-radius: 50%;

            font-size: 18px;

            font-weight: bold;

            cursor: pointer;

            display: flex;

            justify-content: center;

            align-items: center;

        }



        .badge-na {

            background-color: #555;

            color: #eee;

            padding: 4px 8px;

            border-radius: 4px;

            font-size: 12px;

        }



        /* Order Views Styles */

        .order-card {

            background-color: var(--surface-color);

            border: 1px solid var(--border-color);

            border-radius: 8px;

            padding: 25px;

            margin-bottom: 20px;

        }



        .order-header {

            display: flex;

            justify-content: space-between;

            border-bottom: 1px solid var(--border-color);

            padding-bottom: 12px;

            margin-bottom: 15px;

        }



        .order-user {

            font-weight: bold;

            color: var(--primary-color);

        }



        .order-items {

            list-style: none;

            margin-bottom: 15px;

        }



        .order-items li {

            display: flex;

            justify-content: space-between;

            color: var(--text-muted);
margin-bottom: 6px;

        }



        .order-total {

            text-align: right;

            font-weight: bold;

            font-size: 18px;

        }



        .empty-message {

            color: var(--text-muted);

            text-align: center;

            padding: 40px;

            background-color: var(--surface-color);

            border-radius: 8px;

            border: 1px solid var(--border-color);

        }



        /* Cart */

        .cart-fab {

            position: fixed;

            bottom: 30px;

            right: 30px;

            background-color: var(--primary-color);

            color: white;

            border: none;

            width: 64px;

            height: 64px;

            border-radius: 50%;

            font-size: 26px;

            cursor: pointer;

            box-shadow: 0 4px 20px rgba(255, 87, 34, 0.5);

            z-index: 800;

            display: none;

            justify-content: center;

            align-items: center;

            transition: transform 0.2s;

        }

        .cart-fab:hover { transform: scale(1.1); }

        .cart-fab.visible { display: flex; }



        .cart-badge {

            position: absolute;

            top: -4px;

            right: -4px;

            background-color: #fff;

            color: var(--primary-color);

            border-radius: 50%;

            width: 22px;

            height: 22px;

            font-size: 12px;

            font-weight: bold;

            display: none;

            justify-content: center;

            align-items: center;

        }

        .cart-fab.has-items .cart-badge { display: flex; }



        .cart-overlay {

            position: fixed;

            top: 0; left: 0; right: 0; bottom: 0;

            background: rgba(0, 0, 0, 0.6);

            z-index: 1100;

            display: none;

        }

        .cart-overlay.open { display: block; }



        .cart-panel {

            position: fixed;

            top: 0;

            right: 0;

            width: 380px;

            max-width: 100vw;

            height: 100%;

            background-color: var(--surface-color);

            border-left: 1px solid var(--border-color);

            z-index: 1200;

            transform: translateX(100%);

            transition: transform 0.3s ease;

            display: flex;

            flex-direction: column;

        }

        .cart-panel.open { transform: translateX(0); }



        .cart-header {

            padding: 20px;

            border-bottom: 1px solid var(--border-color);

            display: flex;

            justify-content: space-between;

            align-items: center;

        }

        .cart-header h3 { color: var(--primary-color); font-size: 20px; }

        .cart-close-btn {

            background: none;

            border: none;

            color: var(--text-muted);

            font-size: 22px;

            cursor: pointer;

        }

        .cart-close-btn:hover { color: var(--text-color); }



        .cart-items-list {

            flex: 1;

            overflow-y: auto;

            padding: 10px 20px;

        }

        .cart-item {

            display: flex;

            justify-content: space-between;

            align-items: center;

            padding: 12px 0;

            border-bottom: 1px solid var(--border-color);

        }

        .cart-item-info { flex: 1; }

        .cart-item-name { font-size: 14px; }

        .cart-item-price { color: var(--primary-color); font-size: 13px; margin-top: 3px; }

        .cart-item-remove {

            background: none;

            border: none;

            color: #666;

            font-size: 18px;

            cursor: pointer;

            padding: 0 6px;

            line-height: 1;

        }

        .cart-item-remove:hover { color: var(--primary-color); }

        .cart-empty-msg { text-align: center; color: var(--text-muted); padding: 40px 0; }



        .cart-footer {

            padding: 20px;

            border-top: 1px solid var(--border-color);
}

        .cart-total-row {

            display: flex;

            justify-content: space-between;

            font-size: 20px;

            font-weight: bold;

            margin-bottom: 16px;

        }

        .btn-submit-cart {

            width: 100%;

            padding: 16px;

            background-color: var(--primary-color);

            color: white;

            border: none;

            border-radius: 4px;

            font-size: 17px;

            font-weight: bold;

            cursor: pointer;

            transition: background 0.2s;

        }

        .btn-submit-cart:hover { background-color: #e64a19; }

        .btn-submit-cart:disabled { background-color: #555; cursor: not-allowed; }



        .btn-delete-order {

            background: none;

            border: 1px solid #555;

            color: #888;

            padding: 6px 12px;

            border-radius: 4px;

            font-size: 13px;

            cursor: pointer;

            transition: all 0.2s;

            margin-top: 12px;

        }

        .btn-delete-order:hover {

            border-color: #e53935;

            color: #e53935;

            background-color: rgba(229, 57, 53, 0.08);

        }

    </style>

</head>

<body>



    <!-- STEP 1: Auth Fenster -->

    <div id="auth-overlay">

        <div class="auth-card">

            <h2>Konto erstellen</h2>

            <form id="auth-form" onsubmit="handleAuth(event)">

                <div class="form-group">

                    <label for="username">Benutzername</label>

                    <input type="text" id="username" required autocomplete="off">

                </div>

                <div class="form-group">

                    <label for="password">Passwort</label>

                    <input type="password" id="password" required>

                </div>

                <button type="submit" class="btn-primary">Registrieren &amp; Anmelden</button>

            </form>

        </div>

    </div>



    <!-- STEP 2 & 3: Hauptseite nach Login -->

    <div id="main-app">

        <header>

            <div class="main-nav">

                <div class="logo">Panorama Grill</div>

                <ul class="nav-links">

                    <li><a href="#" id="link-speisekarte" class="active" onclick="switchView('speisekarte')">Speisekarte</a></li>

                    <li><a href="#" id="link-meine" onclick="switchView('meine')">Meine Bestellungen</a></li>

                    <li><a href="#" id="link-alle" onclick="switchView('alle')">Alle Bestellungen</a></li>

                </ul>

            </div>



            <!-- Kategorien-Leiste nur für Speisekarte sichtbar -->

            <div class="category-nav" id="sub-header-categories">

                <div class="category-container">

                    <a href="#cat-specials" class="category-link">Specials</a>

                    <a href="#cat-veg" class="category-link">Vegetarisch &amp; Falafel</a>

                    <a href="#cat-doener" class="category-link">Dönergerichte</a>

                    <a href="#cat-pizzen" class="category-link">Pizzen</a>

                    <a href="#cat-snacks" class="category-link">Pizzabrötchen</a>

                    <a href="#cat-pasta" class="category-link">Pastagerichte</a>

                    <a href="#cat-ueberbacken" class="category-link">Überbacken</a>

                    <a href="#cat-saucen" class="category-link">Saucen</a>

                    <a href="#cat-getraenke" class="category-link">Getränke</a>

                </div>

            </div>

        </header>



        <main class="container">

            <!-- VIEW: SPEISEKARTE -->

            <div id="view-speisekarte" class="view active">

                <!-- Die Gerichte werden dynamisch per JavaScript eingefügt -->

            </div>



            <!-- VIEW: MEINE BESTELLUNGEN -->

            <div id="view-meine" class="view">

                <h2 style="margin-bottom: 25px; color: var(--primary-color);">Meine Bestellungen</h2>
<div id="meine-bestellungen-liste"></div>

            </div>



            <!-- VIEW: ALLE BESTELLUNGEN -->

            <div id="view-alle" class="view">

                <h2 style="margin-bottom: 25px; color: var(--primary-color);">Alle Bestellungen (Systemweit)</h2>

                <div id="alle-bestellungen-liste"></div>

            </div>

        </main>

    </div>



    <!-- Cart FAB -->

    <button class="cart-fab" id="cart-fab" onclick="toggleCart()" title="Warenkorb">

        🛒

        <span class="cart-badge" id="cart-badge">0</span>

    </button>



    <!-- Cart Overlay + Panel -->

    <div class="cart-overlay" id="cart-overlay" onclick="toggleCart()"></div>

    <div class="cart-panel" id="cart-panel">

        <div class="cart-header">

            <h3>Warenkorb</h3>

            <button class="cart-close-btn" onclick="toggleCart()">✕</button>

        </div>

        <div class="cart-items-list" id="cart-items-list">

            <div class="cart-empty-msg">Dein Warenkorb ist leer.</div>

        </div>

        <div class="cart-footer">

            <div class="cart-total-row">

                <span>Gesamt</span>

                <span id="cart-total-display">0,00 €</span>

            </div>

            <button class="btn-submit-cart" id="btn-submit-cart" onclick="submitCart()" disabled>

                Jetzt bestellen

            </button>

        </div>

    </div>



    <script>

        let currentUser = "";

        let cart = [];



        // Restore session from localStorage so the page remembers who you are

        const savedUser = localStorage.getItem('pg_user');

