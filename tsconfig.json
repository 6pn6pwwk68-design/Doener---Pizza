        function showApp() {

            document.getElementById('auth-overlay').style.
          display = 'none';

            document.getElementById('main-app').style.display = 'block';

            document.getElementById('cart-fab').classList.add('visible');

            renderSpeisekarte();

        }



        // If a session was restored, skip the login screen immediately

        if (savedUser) {

            showApp();

        }



        function handleAuth(event) {

            event.preventDefault();

            const userInp = document.getElementById('username').value.trim();

            if (userInp) {

                currentUser = userInp;

                localStorage.setItem('pg_user', currentUser);

                showApp();

            }

        }



        function switchView(viewName) {

            document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));

            document.querySelectorAll('.nav-links a').forEach(a => a.classList.remove('active'));



            document.getElementById('view-' + viewName).classList.add('active');

            document.getElementById('link-' + viewName).classList.add('active');



            const subHeader = document.getElementById('sub-header-categories');

            subHeader.style.display = viewName === 'speisekarte' ? 'block' : 'none';



            if (viewName === 'meine') renderMeineBestellungen();

            if (viewName === 'alle') renderAlleBestellungen();

        }



        function renderSpeisekarte() {

            const container = document.getElementById('view-speisekarte');

            container.innerHTML = "";



            const keyMap = {

                specials: "cat-specials",

                veg: "cat-veg",

                doener: "cat-doener",

                pizzen: "cat-pizzen",

                snacks: "cat-snacks",

                pasta: "cat-pasta",

                ueberbacken: "cat-ueberbacken",

                saucen: "cat-saucen",

                getraenke: "cat-getraenke"

            };



            for (let key in menuData) {

                const sectionData = menuData[key];

                const section = document.createElement('section');

                section.className = 'category-section';

                section.id = keyMap[key];



                let html = '<h2>' + sectionData.title + '</h2>';

                if (sectionData.note) {

                    html += '<p class="category-note">' + sectionData.note + '</p>';

                }

                html += '<div class="menu-grid">';



                sectionData.items.forEach(function(item) {

                    const naClass = item.na ? 'not-available' : '';

                    const safeName = item.name.replace(/'/g, "\\'");

                    const safePrice = item.price.replace(/'/g, "\\'");

                    html += '<div class="menu-item ' + naClass + '">';

                    html += '<div class="item-info">';

                    html += '<h3>' + item.name + '</h3>';

                    html += '<p class="item-description">' + (item.desc || '') + '</p>';

                    html += '</div>';

                    html += '<div class="item-footer">';

                    html += '<span class="item-price">' + item.price + '</span>';

                    if (item.na) {

                        html += '<span class="badge-na">Nicht verfügbar</span>';

                    } else {

                        html += '<button class="btn-add" onclick="addToCart(this, \'' + safeName + '\', \'' + safePrice + '\')">+</button>';

                    }

                    html += '</div></div>';

                });



                html += '</div>';

                section.innerHTML = html;

                container.appendChild(section);

            }

        }



        function parsePrice(preis) {

            const clean = preis.replace('ab ', '').replace(' €', '').replace(',', '.').trim();

            const match = clean.match(/[\d.]+/);

            return match ? parseFloat(match[0]) : 0;

        }



        function addToCart(btn, name, preis) {

            cart.
          push({ name, preis });

            updateCartUI();

            btn.textContent = '✓';

            btn.style.backgroundColor = '#4caf50';

            setTimeout(function() {

                btn.textContent = '+';

                btn.style.backgroundColor = '';

            }, 700);

        }



        function removeFromCart(idx) {

            cart.splice(idx, 1);

            updateCartUI();

        }



        function updateCartUI() {

            const count = cart.length;

            const fab = document.getElementById('cart-fab');

            const badge = document.getElementById('cart-badge');

            const list = document.getElementById('cart-items-list');

            const totalEl = document.getElementById('cart-total-display');

            const submitBtn = document.getElementById('btn-submit-cart');



            badge.textContent = count;

            fab.classList.toggle('has-items', count > 0);



            if (count === 0) {

                list.innerHTML = '<div class="cart-empty-msg">Dein Warenkorb ist leer.</div>';

            } else {

                list.innerHTML = '';

                cart.forEach(function(item, idx) {

                    const div = document.createElement('div');

                    div.className = 'cart-item';

                    div.innerHTML =

                        '<div class="cart-item-info">' +

                        '<div class="cart-item-name">' + item.name + '</div>' +

                        '<div class="cart-item-price">' + item.preis + '</div>' +

                        '</div>' +

                        '<button class="cart-item-remove" onclick="removeFromCart(' + idx + ')">✕</button>';

                    list.appendChild(div);

                });

            }



            const total = cart.reduce(function(sum, item) { return sum + parsePrice(item.preis); }, 0);

            totalEl.textContent = total.toFixed(2).replace('.', ',') + ' €';

            submitBtn.disabled = count === 0;

        }



        function toggleCart() {

            const panel = document.getElementById('cart-panel');

            const overlay = document.getElementById('cart-overlay');

            const isOpen = panel.classList.contains('open');

            panel.classList.toggle('open', !isOpen);

            overlay.classList.toggle('open', !isOpen);

        }



        async function submitCart() {

            if (cart.length === 0) return;

            const btn = document.getElementById('btn-submit-cart');

            btn.disabled = true;

            btn.textContent = 'Wird bestellt…';

            try {

                const items = cart.map(function(item) { return '1x ' + item.name; });

                const total = cart.reduce(function(sum, item) { return sum + parsePrice(item.preis); }, 0);

                const totalStr = total.toFixed(2).replace('.', ',') + ' €';

                const res = await fetch('/api/orders', {

                    method: 'POST',

                    headers: { 'Content-Type': 'application/json' },

                    body: JSON.stringify({ username: currentUser, items: items, total: totalStr })

                });

                if (!res.ok) throw new Error('Fehler beim Speichern');

                cart = [];

                updateCartUI();

                toggleCart();

                alert('Bestellung erfolgreich aufgegeben!');

            } catch (e) {

                alert('Fehler: Bestellung konnte nicht gespeichert werden.');

            } finally {

                btn.disabled = cart.length === 0;

                btn.textContent = 'Jetzt bestellen';

            }

        }



        async function renderMeineBestellungen() {

            const listContainer = document.getElementById('meine-bestellungen-liste');

            listContainer.innerHTML = '<div class="empty-message">Wird geladen…</div>';

            try {

                const res = await fetch('/api/orders?username=' + encodeURIComponent(currentUser));

                const orders = await res.json();
          listContainer.innerHTML = "";

                if (orders.length === 0) {

                    listContainer.innerHTML = '<div class="empty-message">Du hast noch keine Bestellungen getätigt.</div>';

                    return;

                }

                orders.forEach(function(o) { listContainer.appendChild(createOrderCard(o, false, true)); });

            } catch (e) {

                listContainer.innerHTML = '<div class="empty-message">Fehler beim Laden der Bestellungen.</div>';

            }

        }



        async function renderAlleBestellungen() {

            const listContainer = document.getElementById('alle-bestellungen-liste');

            listContainer.innerHTML = '<div class="empty-message">Wird geladen…</div>';

            try {

                const res = await fetch('/api/orders');

                const orders = await res.json();

                listContainer.innerHTML = "";

                if (orders.length === 0) {

                    listContainer.innerHTML = '<div class="empty-message">Es liegen keine Systembestellungen vor.</div>';

                    return;

                }

                orders.forEach(function(o) { listContainer.appendChild(createOrderCard(o, true)); });

            } catch (e) {

                listContainer.innerHTML = '<div class="empty-message">Fehler beim Laden der Bestellungen.</div>';

            }

        }



        function createOrderCard(order, showUser, canDelete) {

            const card = document.createElement('div');

            card.className = 'order-card';

            card.id = 'order-card-' + order.id;

            let itemsHtml = "";

            const items = Array.isArray(order.items) ? order.items : [];

            items.forEach(function(i) { itemsHtml += '<li>' + i + '</li>'; });



            const date = order.createdAt ? new Date(order.createdAt).toLocaleString('de-DE') : '';

            card.innerHTML =

                '<div class="order-header">' +

                '<span>Bestell-ID: #' + order.id + (date ? ' &nbsp;·&nbsp; ' + date : '') + '</span>' +

                (showUser ? '<span class="order-user">Kunde: ' + order.username + '</span>' : '') +

                '</div>' +

                '<ul class="order-items">' + itemsHtml + '</ul>' +

                '<div class="order-total">Gesamt: ' + order.total + '</div>' +

                (canDelete ? '<button class="btn-delete-order" onclick="deleteOrder(' + order.id + ')">Bestellung löschen</button>' : '');

            return card;

        }



        async function deleteOrder(id) {

            if (!confirm('Möchtest du diese Bestellung wirklich löschen?')) return;

            try {

                const res = await fetch('/api/orders?id=' + id + '&username=' + encodeURIComponent(currentUser), {

                    method: 'DELETE'

                });

                if (res.status === 403) {

                    alert('Du kannst nur deine eigenen Bestellungen löschen.');

                    return;

                }

                if (!res.ok && res.status !== 204) {

                    throw new Error('Fehler');

                }

                const card = document.getElementById('order-card-' + id);

                if (card) card.remove();

                const list = document.getElementById('meine-bestellungen-liste');

                if (list && list.children.length === 0) {

                    list.innerHTML = '<div class="empty-message">Du hast noch keine Bestellungen getätigt.</div>';

                }

            } catch (e) {

                alert('Fehler beim Löschen der Bestellung.');

            }

        }

    </script>

